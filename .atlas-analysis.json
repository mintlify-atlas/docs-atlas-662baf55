  "keyFeatures": [
    "Full PKCS#11 v3.2 interface implementation as a shared library (libsofthsm2)",
    "Support for RSA, DSA, ECDSA, ECDH, EdDSA, DH, GOST, and ML-DSA (post-quantum) algorithms",
    "Pluggable crypto backends: OpenSSL and Botan",
    "File-based and SQLite3 database object store backends",
    "CLI tools: softhsm2-util, softhsm2-keyconv, softhsm2-migrate, softhsm2-dump",
    "p11-kit integration for system-wide PKCS#11 module registration",
    "FIPS 140-2 support via OpenSSL FIPS-capable library",
    "Cross-platform: Linux, macOS, and Windows",
    "Secure non-paged memory for sensitive key material",
    "Configurable mechanism allow/deny lists"
  ],
  "publicApiSurface": [
    "C_Initialize / C_Finalize",
    "C_GetSlotList / C_GetSlotInfo / C_GetTokenInfo",
    "C_InitToken / C_InitPIN / C_SetPIN",
    "C_OpenSession / C_CloseSession / C_Login / C_Logout",
    "C_CreateObject / C_DestroyObject / C_FindObjects",
    "C_Encrypt / C_Decrypt",
    "C_Sign / C_Verify",
    "C_Digest",
    "C_GenerateKey / C_GenerateKeyPair",
    "C_WrapKey / C_UnwrapKey / C_DeriveKey",
    "C_GenerateRandom / C_SeedRandom",
    "softhsm2-util --init-token / --show-slots / --import / --delete-token",
    "softhsm2-keyconv --in / --out / --pin",
    "softhsm2-migrate",
    "softhsm2-dump-file / softhsm2-dump-db"
  ]
